{
  "name": "spec-clipboard",
  "private": true,
  "version": "1.0.5",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:win": "set NODE_ENV=development&& electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npx cross-env NODE_ENV=development .\\node_modules\\.bin\\electron.cmd .\"",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.specclipboard.app",
    "productName": "스펙 복사기",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SpecClip_Setup_${version}.exe"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.js"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "firebase": "^12.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}